# tarka — grad-check suite: the correctness gate for the REINFORCE policy.
# Inherits attn11's discipline — every hand-derived backward is verified against
# central finite differences before it lands. Dogfoods rosnet's linear_bwd.
# Stdlib auto-included via cyrius.cyml.

include "lib/tyche.cyr"
include "lib/rosnet.cyr"
include "lib/akshara.cyr"
include "src/rl.cyr"
include "src/actorcritic.cyr"
include "src/reward.cyr"
include "src/dpo.cyr"

fn _putc(ch): i64 { var b[8]; store8(&b, ch); sys_write(1, &b, 1); return 0; }
fn puts(s): i64 { var n = 0; while (load8(s + n) != 0) { n = n + 1; } print(s, n); return 0; }
# akshara consumer symbols unused on the pure tokenizer path — stub for a clean build
fn secure_read_file(path, buf, cap): i64 { return 0 - 1; }
fn read_stdin(buf, cap): i64 { return 0 - 1; }
fn file_seek(fd, off): i64 { return 0 - 1; }
fn EPS(): i64 { return f64_div(f64_from(1), f64_from(10000)); }              # 1e-4
fn TOL(): i64 { return f64_div(f64_from(1), f64_from(100000)); }            # 1e-5
fn TOL_EXACT(): i64 { return f64_div(f64_from(1), f64_from(1000000000)); }  # 1e-9

# central finite-difference grad of pol_ce(x,a) wrt parameter P[idx]
fn fd_grad(P, idx, x, a): i64 {
    var save = load64(P + idx * 8);
    store64(P + idx * 8, f64_add(save, EPS()));
    var lp = pol_ce(x, a);
    store64(P + idx * 8, f64_sub(save, EPS()));
    var lm = pol_ce(x, a);
    store64(P + idx * 8, save);
    return f64_div(f64_sub(lp, lm), f64_mul(f64_from(2), EPS()));
}

fn relerr(fd, an): i64 {
    var num = f64_abs(f64_sub(fd, an));
    var den = f64_add(f64_abs(an), f64_div(f64_from(1), f64_from(1000000000)));
    return f64_div(num, den);
}

# show maxrel scaled by 1e9 (so a passing ~1e-7 prints as a few hundred)
fn show(label, mr): i64 { puts(label); fmt_int(f64_to(f64_mul(mr, f64_from(1000000000)))); puts(" e-9\n"); return 0; }

# max relerr of analytic grad G vs FD over parameter block P (n entries) for (x,a)
fn check_block(P, G, n, x, a): i64 {
    var mr = f64_from(0);
    var i = 0;
    while (i < n) {
        var re = relerr(fd_grad(P, i, x, a), load64(G + i * 8));
        if (f64_gt(re, mr) == 1) { mr = re; }
        i = i + 1;
    }
    return mr;
}

# central FD grad of the critic loss ½(V(x)-target)² wrt parameter P[idx]
fn fd_vgrad(P, idx, x, target): i64 {
    var save = load64(P + idx * 8);
    store64(P + idx * 8, f64_add(save, EPS())); var lp = val_loss(x, target);
    store64(P + idx * 8, f64_sub(save, EPS())); var lm = val_loss(x, target);
    store64(P + idx * 8, save);
    return f64_div(f64_sub(lp, lm), f64_mul(f64_from(2), EPS()));
}
fn check_vblock(P, G, n, x, target): i64 {
    var mr = f64_from(0); var i = 0;
    while (i < n) {
        var re = relerr(fd_vgrad(P, i, x, target), load64(G + i * 8));
        if (f64_gt(re, mr) == 1) { mr = re; }
        i = i + 1;
    }
    return mr;
}
# central FD grad of the Bradley-Terry pair loss wrt RM parameter P[idx]
fn fd_rm(P, idx, stW, acW, stL, acL, n): i64 {
    var save = load64(P + idx * 8);
    store64(P + idx * 8, f64_add(save, EPS())); var lp = rm_pair_loss(stW, acW, stL, acL, n);
    store64(P + idx * 8, f64_sub(save, EPS())); var lm = rm_pair_loss(stW, acW, stL, acL, n);
    store64(P + idx * 8, save);
    return f64_div(f64_sub(lp, lm), f64_mul(f64_from(2), EPS()));
}
fn check_rmblock(P, G, n, stW, acW, stL, acL, sn): i64 {
    var mr = f64_from(0); var i = 0;
    while (i < n) {
        var re = relerr(fd_rm(P, i, stW, acW, stL, acL, sn), load64(G + i * 8));
        if (f64_gt(re, mr) == 1) { mr = re; }
        i = i + 1;
    }
    return mr;
}

# central FD grad of the PPO surrogate -L_t wrt parameter P[idx]
fn fd_ppo(P, idx, x, a, lp_old, A): i64 {
    var save = load64(P + idx * 8);
    store64(P + idx * 8, f64_add(save, EPS())); var lp = ppo_loss(x, a, lp_old, A, CLIP_EPS());
    store64(P + idx * 8, f64_sub(save, EPS())); var lm = ppo_loss(x, a, lp_old, A, CLIP_EPS());
    store64(P + idx * 8, save);
    return f64_div(f64_sub(lp, lm), f64_mul(f64_from(2), EPS()));
}

# independent explicit GAE advantage A_t = Σ_{l≥0} (γλ)^l · delta_{t+l} (vs the recursion)
fn gae_explicit(t, dbuf): i64 {
    var A = f64_from(0); var p = f64_from(1); var l = 0;
    while (t + l < g_T) {
        A = f64_add(A, f64_mul(p, load64(dbuf + (t + l) * 8)));
        p = f64_mul(p, GLAM());
        l = l + 1;
    }
    return A;
}

# central FD grad of the DPO pair loss wrt POLICY parameter P[idx] (reference frozen)
fn fd_dpo(P, idx, stW, acW, stL, acL, n, beta): i64 {
    var save = load64(P + idx * 8);
    store64(P + idx * 8, f64_add(save, EPS())); var lp = dpo_pair_loss(stW, acW, stL, acL, n, beta);
    store64(P + idx * 8, f64_sub(save, EPS())); var lm = dpo_pair_loss(stW, acW, stL, acL, n, beta);
    store64(P + idx * 8, save);
    return f64_div(f64_sub(lp, lm), f64_mul(f64_from(2), EPS()));
}
fn check_dpoblock(P, G, np, stW, acW, stL, acL, n, beta): i64 {
    var mr = f64_from(0); var i = 0;
    while (i < np) {
        var re = relerr(fd_dpo(P, i, stW, acW, stL, acL, n, beta), load64(G + i * 8));
        if (f64_gt(re, mr) == 1) { mr = re; }
        i = i + 1;
    }
    return mr;
}
# central FD grad of the KL penalty β·KL(p‖q) wrt POLICY parameter P[idx] (reference frozen)
fn fd_kl(P, idx, x, beta): i64 {
    var save = load64(P + idx * 8);
    store64(P + idx * 8, f64_add(save, EPS())); var lp = kl_loss(x, beta);
    store64(P + idx * 8, f64_sub(save, EPS())); var lm = kl_loss(x, beta);
    store64(P + idx * 8, save);
    return f64_div(f64_sub(lp, lm), f64_mul(f64_from(2), EPS()));
}
fn check_klblock(P, G, np, x, beta): i64 {
    var mr = f64_from(0); var i = 0;
    while (i < np) {
        var re = relerr(fd_kl(P, i, x, beta), load64(G + i * 8));
        if (f64_gt(re, mr) == 1) { mr = re; }
        i = i + 1;
    }
    return mr;
}

fn main() {
    alloc_init();

    test_group("policy backward grad-check (rosnet linear_bwd + softmax-CE)");
    pol_init(8, 4, 1, 3, 99);                 # V=8 D=4 T=1
    var x = 2; var a = 5;
    store64(R_states, x); store64(R_actions, a);
    pol_zero_grads();
    rl_backward(f64_from(1));                  # analytic grad at scale 1 -> G_W,G_b,G_E

    var mrW = check_block(P_W, G_W, g_D * g_V, x, a);
    var mrE = check_block(P_E, G_E, g_V * g_D, x, a);
    var mrB = check_block(P_b, G_b, g_V, x, a);
    show("  dW maxrel = ", mrW); show("  dE maxrel = ", mrE); show("  db maxrel = ", mrB);
    assert(f64_lt(mrW, TOL()), "dW (head weight) FD grad-check");
    assert(f64_lt(mrE, TOL()), "dE (embedding) FD grad-check");
    assert(f64_lt(mrB, TOL()), "db (head bias) FD grad-check");

    test_group("RL advantage-scaling: grad(scale=A) == A * grad(scale=1)");
    pol_init(8, 4, 5, 3, 7);                   # V=8 D=4 T=5
    rl_rollout(rl_prompt());                   # freeze a sampled rollout
    pol_zero_grads(); rl_backward(f64_from(1));
    var base = t_alloc(g_D * g_V); t_copy(base, G_W, g_D * g_V);
    var A = f64_div(f64_from(5), f64_from(2)); # 2.5
    pol_zero_grads(); rl_backward(A);
    var mrS = f64_from(0);
    var i = 0;
    while (i < g_D * g_V) {
        var re = relerr(load64(G_W + i * 8), f64_mul(A, load64(base + i * 8)));
        if (f64_gt(re, mrS) == 1) { mrS = re; }
        i = i + 1;
    }
    show("  scaling maxrel = ", mrS);
    assert(f64_lt(mrS, TOL_EXACT()), "RL grad == advantage * CE grad (exact to rounding)");

    test_group("critic (value head) backward grad-check");
    pol_init(8, 4, 1, 3, 99); ac_init();      # V=8 D=4 T=1
    var cx = 2;
    store64(R_states, cx);
    store64(R_ret, f64_div(f64_from(7), f64_from(10)));    # arbitrary critic target 0.7
    pol_zero_grads(); val_zero_grads();
    critic_backward(f64_from(1));              # analytic grads -> G_wv, G_bv, G_E (shared)
    var ctgt = load64(R_ret);
    var mrWv = check_vblock(P_wv, G_wv, g_D, cx, ctgt);
    var mrBv = check_vblock(P_bv, G_bv, 1, cx, ctgt);
    var mrVe = check_vblock(P_E, G_E, g_V * g_D, cx, ctgt);
    show("  dWv maxrel = ", mrWv); show("  dBv maxrel = ", mrBv); show("  dE(critic) maxrel = ", mrVe);
    assert(f64_lt(mrWv, TOL()), "critic dW (value weight) FD grad-check");
    assert(f64_lt(mrBv, TOL()), "critic db (value bias) FD grad-check");
    assert(f64_lt(mrVe, TOL()), "critic dE (shared embedding) FD grad-check");

    test_group("actor-critic GAE: recursion == explicit (γλ)^l sum (boundary + role check)");
    pol_init(8, 4, 5, 3, 7); ac_init();        # T=5
    # arbitrary rewards + values (set directly; no rollout needed for the recursion check)
    store64(R_rewards + 0*8, f64_from(1)); store64(R_rewards + 1*8, f64_from(0));
    store64(R_rewards + 2*8, f64_from(1)); store64(R_rewards + 3*8, f64_from(0));
    store64(R_rewards + 4*8, f64_from(1));
    store64(R_values + 0*8, f64_div(f64_from(5),f64_from(10)));   # 0.5
    store64(R_values + 1*8, f64_div(f64_from(3),f64_from(10)));   # 0.3
    store64(R_values + 2*8, f64_div(f64_from(8),f64_from(10)));   # 0.8
    store64(R_values + 3*8, f64_div(f64_from(2),f64_from(10)));   # 0.2
    store64(R_values + 4*8, f64_div(f64_from(4),f64_from(10)));   # 0.4
    gae_advantages();                          # fills R_adv via the backward recursion
    # independent: delta_t = r_t + γ·V(s_{t+1}) - V(s_t), V(s_T)=0
    var dbuf = t_alloc(g_T);
    var gt = 0;
    while (gt < g_T) {
        var vn = f64_from(0);
        if (gt < g_T - 1) { vn = load64(R_values + (gt + 1) * 8); }
        store64(dbuf + gt * 8, f64_sub(f64_add(load64(R_rewards + gt*8), f64_mul(GAMMA(), vn)),
                                       load64(R_values + gt*8)));
        gt = gt + 1;
    }
    var mrGae = f64_from(0); gt = 0;
    while (gt < g_T) {
        var re = relerr(load64(R_adv + gt * 8), gae_explicit(gt, dbuf));
        if (f64_gt(re, mrGae) == 1) { mrGae = re; }
        gt = gt + 1;
    }
    show("  GAE recursion-vs-explicit maxrel = ", mrGae);
    assert(f64_lt(mrGae, TOL_EXACT()), "GAE A_t recursion == explicit (γλ)^l sum (exact)");
    # return identity: Ghat_t == A_t + V(s_t)
    var mrRet = f64_from(0); gt = 0;
    while (gt < g_T) {
        var re = relerr(load64(R_ret + gt*8), f64_add(load64(R_adv + gt*8), load64(R_values + gt*8)));
        if (f64_gt(re, mrRet) == 1) { mrRet = re; }
        gt = gt + 1;
    }
    assert(f64_lt(mrRet, TOL_EXACT()), "GAE return Ghat_t == A_t + V(s_t) (exact)");

    test_group("actor-critic PPO: rho=1 == advantage-REINFORCE, clip zeroes, FD unclipped");
    pol_init(8, 4, 1, 3, 99); ac_init();      # T=1
    store64(R_states, 2); store64(R_actions, 5);
    var Appo = f64_div(f64_from(3), f64_from(2));   # advantage 1.5
    store64(R_adv, Appo);
    # (a) rho=1: snapshot at current params -> ppo_backward seed == rl_backward(A) exactly
    ppo_snapshot();
    pol_zero_grads(); ppo_backward();
    var ppoW = t_alloc(g_D * g_V); t_copy(ppoW, G_W, g_D * g_V);
    pol_zero_grads(); rl_backward(Appo);
    var mrPP = f64_from(0); var pi = 0;
    while (pi < g_D * g_V) { var re = relerr(load64(ppoW + pi*8), load64(G_W + pi*8)); if (f64_gt(re, mrPP) == 1) { mrPP = re; } pi = pi + 1; }
    show("  PPO rho=1 vs REINFORCE maxrel = ", mrPP);
    assert(f64_lt(mrPP, TOL_EXACT()), "PPO rho=1 seed == advantage-REINFORCE (exact)");
    # (b) FD of the unclipped surrogate (rho=1) wrt P_W == ppo_backward G_W
    var lp0 = load64(R_logpold);
    pol_zero_grads(); ppo_backward();
    var mrPU = f64_from(0); pi = 0;
    while (pi < g_D * g_V) { var re = relerr(fd_ppo(P_W, pi, 2, 5, lp0, Appo), load64(G_W + pi*8)); if (f64_gt(re, mrPU) == 1) { mrPU = re; } pi = pi + 1; }
    show("  PPO unclipped FD maxrel = ", mrPU);
    assert(f64_lt(mrPU, TOL()), "PPO unclipped surrogate FD grad-check");
    # (c) clipped: rho = exp(+1) ~ 2.718 > 1+eps, A>0 -> binding clip -> X=0 -> G_W all zero
    store64(R_logpold, f64_sub(lp0, f64_from(1)));
    pol_zero_grads(); ppo_backward();
    var maxG = f64_from(0); pi = 0;
    while (pi < g_D * g_V) { var ag = f64_abs(load64(G_W + pi*8)); if (f64_gt(ag, maxG) == 1) { maxG = ag; } pi = pi + 1; }
    show("  PPO clipped max|G_W| = ", maxG);
    assert(f64_lt(maxG, TOL_EXACT()), "PPO binding clip (A>0, rho>1+eps) -> zero gradient");

    test_group("actor-critic GRPO: group-relative advantage + ratio=1 seed");
    pol_init(8, 4, 3, 3, 7); ac_init();        # T=3
    # group-norm {2,1} (G=2) -> [+1,-1]
    store64(GR_R + 0*8, f64_from(2)); store64(GR_R + 1*8, f64_from(1)); grpo_group_adv(2);
    assert(f64_lt(relerr(load64(GR_adv + 0*8), f64_from(1)), TOL()), "GRPO {2,1} -> Â_0=+1");
    assert(f64_lt(relerr(load64(GR_adv + 1*8), f64_neg(f64_from(1))), TOL()), "GRPO {2,1} -> Â_1=-1");
    # {0,1,2} (G=3) -> [-sqrt(3/2), 0, +sqrt(3/2)]
    store64(GR_R + 0*8, f64_from(0)); store64(GR_R + 1*8, f64_from(1)); store64(GR_R + 2*8, f64_from(2)); grpo_group_adv(3);
    var s32 = f64_sqrt(f64_div(f64_from(3), f64_from(2)));
    assert(f64_lt(relerr(load64(GR_adv + 0*8), f64_neg(s32)), TOL()), "GRPO {0,1,2} -> Â_0=-sqrt(3/2)");
    assert(f64_lt(f64_abs(load64(GR_adv + 1*8)), TOL()), "GRPO {0,1,2} -> Â_1=0");
    assert(f64_lt(relerr(load64(GR_adv + 2*8), s32), TOL()), "GRPO {0,1,2} -> Â_2=+sqrt(3/2)");
    # all-equal -> 0 (no NaN: 0/(0+eps))
    store64(GR_R + 0*8, f64_from(5)); store64(GR_R + 1*8, f64_from(5)); store64(GR_R + 2*8, f64_from(5)); grpo_group_adv(3);
    var maxA = f64_from(0); var gi = 0;
    while (gi < 3) { var ag = f64_abs(load64(GR_adv + gi*8)); if (f64_gt(ag, maxA) == 1) { maxA = ag; } gi = gi + 1; }
    assert(f64_lt(maxA, TOL_EXACT()), "GRPO all-equal group -> Â=0 (no NaN)");
    # ratio=1 anchor: fill group row 0 from a rollout, snapshot, grpo_backward(1) == rl_backward(Â)
    rl_rollout(rl_prompt());
    var gt2 = 0;
    while (gt2 < g_T) { store64(GR_states + gt2*8, load64(R_states + gt2*8)); store64(GR_actions + gt2*8, load64(R_actions + gt2*8)); gt2 = gt2 + 1; }
    gt2 = 0;
    while (gt2 < g_T) {
        var gx = load64(GR_states + gt2*8); var ga = load64(GR_actions + gt2*8);
        pol_logits(gx); pol_softmax();
        store64(GR_oldlp + gt2*8, f64_ln(load64(S_probs + ga*8)));
        gt2 = gt2 + 1;
    }
    var Agr = f64_div(f64_from(7), f64_from(10));   # advantage 0.7
    store64(GR_adv, Agr);
    pol_zero_grads(); grpo_backward(1, f64_from(1));   # G=1, invN=1, ratio=1 -> seed = Â per step
    var grW = t_alloc(g_D * g_V); t_copy(grW, G_W, g_D * g_V);
    pol_zero_grads(); rl_backward(Agr);                # reference over R_states/R_actions (= group row 0)
    var mrGR = f64_from(0); gi = 0;
    while (gi < g_D * g_V) { var re = relerr(load64(grW + gi*8), load64(G_W + gi*8)); if (f64_gt(re, mrGR) == 1) { mrGR = re; } gi = gi + 1; }
    show("  GRPO ratio=1 vs REINFORCE maxrel = ", mrGR);
    assert(f64_lt(mrGR, TOL_EXACT()), "GRPO ratio=1 seed == advantage-REINFORCE (exact)");

    test_group("reward model — Bradley-Terry FD grad-check + descent direction");
    pol_init(8, 4, 2, 3, 99); rm_init();       # V=8 D=4, pair length n=2
    var stW = t_alloc(2); var acW = t_alloc(2); var stL = t_alloc(2); var acL = t_alloc(2);
    store64(stW + 0*8, 1); store64(stW + 1*8, 3); store64(acW + 0*8, 2); store64(acW + 1*8, 5);
    store64(stL + 0*8, 0); store64(stL + 1*8, 4); store64(acL + 0*8, 6); store64(acL + 1*8, 1);
    rm_zero_grads(); rm_backward_pair(stW, acW, stL, acL, 2);   # analytic grads
    var mrRW = check_rmblock(P_Wr, G_Wr, g_D*g_V, stW, acW, stL, acL, 2);
    var mrRB = check_rmblock(P_br, G_br, g_V, stW, acW, stL, acL, 2);
    var mrRE = check_rmblock(P_Er, G_Er, g_V*g_D, stW, acW, stL, acL, 2);
    show("  RM dWr maxrel = ", mrRW); show("  RM dbr maxrel = ", mrRB); show("  RM dEr maxrel = ", mrRE);
    assert(f64_lt(mrRW, TOL()), "RM dWr (head) Bradley-Terry FD grad-check");
    assert(f64_lt(mrRB, TOL()), "RM dbr (bias) Bradley-Terry FD grad-check");
    assert(f64_lt(mrRE, TOL()), "RM dEr (embedding) Bradley-Terry FD grad-check");
    # descent-direction falsifier: one BT step must INCREASE Δ = R(W)−R(L) (catches a
    # gW/gL sign swap that the loss-FD alone cannot see). Guard finiteness first.
    var d0 = f64_sub(rm_score(stW, acW, 2), rm_score(stL, acL, 2));
    rm_zero_grads(); rm_backward_pair(stW, acW, stL, acL, 2);
    rm_adam_step(f64_div(f64_from(1), f64_from(10)));   # lr 0.1
    var d1 = f64_sub(rm_score(stW, acW, 2), rm_score(stL, acL, 2));
    assert((f64_is_finite(d0) == 1) && (f64_is_finite(d1) == 1), "RM Δ finite");
    assert(f64_gt(d1, d0) == 1, "RM Bradley-Terry descent increases Δ (preference direction)");

    test_group("DPO — direct-preference pairwise loss FD grad-check (frozen reference policy)");
    pol_init(8, 4, 2, 3, 99); dpo_init();          # V=8 D=4, preference-pair length n=2
    dpo_snapshot();                                # reference policy π_ref = current θ
    # move θ off the reference so Δ != 0 (a representative, non-degenerate test)
    rng_seed(123);
    t_randn(P_E, 8 * 4, f64_div(f64_from(1), f64_from(10)));
    t_randn(P_W, 4 * 8, f64_div(f64_from(1), f64_from(10)));
    var dstW = t_alloc(2); var dacW = t_alloc(2); var dstL = t_alloc(2); var dacL = t_alloc(2);
    store64(dstW + 0*8, 1); store64(dstW + 1*8, 3); store64(dacW + 0*8, 2); store64(dacW + 1*8, 5);
    store64(dstL + 0*8, 0); store64(dstL + 1*8, 4); store64(dacL + 0*8, 6); store64(dacL + 1*8, 1);
    var dbeta = DPO_BETA();
    pol_zero_grads(); dpo_backward_pair(dstW, dacW, dstL, dacL, 2, dbeta);   # analytic grads -> G_W,G_b,G_E
    var mrDW = check_dpoblock(P_W, G_W, g_D * g_V, dstW, dacW, dstL, dacL, 2, dbeta);
    var mrDb = check_dpoblock(P_b, G_b, g_V, dstW, dacW, dstL, dacL, 2, dbeta);
    var mrDE = check_dpoblock(P_E, G_E, g_V * g_D, dstW, dacW, dstL, dacL, 2, dbeta);
    show("  DPO dW maxrel = ", mrDW); show("  DPO dE maxrel = ", mrDE); show("  DPO db maxrel = ", mrDb);
    assert(f64_lt(mrDW, TOL()), "DPO dW (head weight) FD grad-check");
    assert(f64_lt(mrDE, TOL()), "DPO dE (embedding) FD grad-check");
    assert(f64_lt(mrDb, TOL()), "DPO db (head bias) FD grad-check");
    # descent-direction falsifier: gradient descent on L=−lnσ(Δ) must INCREASE Δ (raise the
    # winner's implicit reward over the loser) — catches a winner/loser scale sign swap.
    var dd0 = dpo_delta(dstW, dacW, dstL, dacL, 2, dbeta);
    pol_zero_grads(); dpo_backward_pair(dstW, dacW, dstL, dacL, 2, dbeta);
    pol_adam_step(f64_div(f64_from(1), f64_from(10)));         # lr 0.1
    var dd1 = dpo_delta(dstW, dacW, dstL, dacL, 2, dbeta);
    assert((f64_is_finite(dd0) == 1) && (f64_is_finite(dd1) == 1), "DPO Δ finite");
    assert(f64_gt(dd1, dd0) == 1, "DPO step increases Δ (preference direction)");

    test_group("RLHF KL-to-reference-policy penalty — FD grad-check + pull-to-reference");
    pol_init(8, 4, 1, 3, 99); dpo_init();          # V=8 D=4
    dpo_snapshot();                                # reference = current θ
    rng_seed(321);
    t_randn(P_E, 8 * 4, f64_div(f64_from(1), f64_from(10)));
    t_randn(P_W, 4 * 8, f64_div(f64_from(1), f64_from(10)));   # θ now diverges from π_ref -> KL > 0
    var kx = 2; var kbeta = f64_div(f64_from(1), f64_from(10));    # β = 0.1
    pol_zero_grads(); kl_backward_state(kx, kbeta);            # analytic grads -> G_W,G_b,G_E
    var mrKW = check_klblock(P_W, G_W, g_D * g_V, kx, kbeta);
    var mrKb = check_klblock(P_b, G_b, g_V, kx, kbeta);
    var mrKE = check_klblock(P_E, G_E, g_V * g_D, kx, kbeta);
    show("  KL dW maxrel = ", mrKW); show("  KL dE maxrel = ", mrKE); show("  KL db maxrel = ", mrKb);
    assert(f64_lt(mrKW, TOL()), "KL penalty dW FD grad-check");
    assert(f64_lt(mrKE, TOL()), "KL penalty dE FD grad-check");
    assert(f64_lt(mrKb, TOL()), "KL penalty db FD grad-check");
    # falsifier: a descent step on β·KL pulls the policy TOWARD the reference (KL decreases).
    var kl0 = kl_div_at(kx);
    pol_zero_grads(); kl_backward_state(kx, kbeta);
    pol_adam_step(f64_div(f64_from(1), f64_from(1000)));       # small lr 0.001 (avoid overshoot past KL=0)
    var kl1 = kl_div_at(kx);
    assert((f64_is_finite(kl0) == 1) && (f64_is_finite(kl1) == 1), "KL finite");
    assert(f64_lt(kl1, kl0) == 1, "KL penalty step reduces KL (pulls policy toward reference)");

    return assert_summary();
}

var exit_code = main();
syscall(60, exit_code);
